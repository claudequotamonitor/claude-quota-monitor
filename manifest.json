{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "version": "1.6",
  "description": "__MSG_ext_description__",
  "default_locale": "pt_BR",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": ["https://claude.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Quota",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["onboarding.html", "onboarding.css", "onboarding.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "homepage_url": "https://claudequotamonitor.github.io",
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
